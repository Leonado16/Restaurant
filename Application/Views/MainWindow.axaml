<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Restaurant.Views"
        xmlns:vm="using:Restaurant.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Restaurant.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Restaurant">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- TOP PANEL -->
        <Border DockPanel.Dock="Top"
                Height="140"
                Background="#C0544C"
                Padding="10">
            <views:QueueView DataContext="{Binding Queue}" />
        </Border>

        <!-- TABS -->
        <Border>
            <TabControl ItemsSource="{Binding Stations}" TabStripPlacement="Bottom">


                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StationViewModel">
                        <TextBlock Text="{Binding StationType}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <!-- TAB CONTENT -->
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:StationViewModel">
                        <views:StationView />
                    </DataTemplate>
                </TabControl.ContentTemplate>

                <!-- <TabControl.ItemTemplate>
                <DataTemplate>
                <TextBlock Text="{Binding StationType}" />
                </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>
                <DataTemplate>
                <views:StationView />
                </DataTemplate>
                </TabControl.ContentTemplate> -->
                </TabControl>

        </Border>
    </DockPanel>
</Window>
